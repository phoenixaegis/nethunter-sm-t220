# NetHunter kernel config additions for SM-T220 (gta7litewifi) — kernel 4.19.191

# USB Gadget (HID attacks)
CONFIG_USB_GADGET=y
CONFIG_USB_CONFIGFS=y
CONFIG_USB_CONFIGFS_F_HID=y
CONFIG_USB_CONFIGFS_RNDIS=y
CONFIG_USB_CONFIGFS_MASS_STORAGE=y

# Wireless (monitor mode + injection)
CONFIG_CFG80211=y
CONFIG_MAC80211=y
CONFIG_MAC80211_MESH=y

# Realtek USB WiFi adapters
CONFIG_RTL8187=m
CONFIG_RTLWIFI=m
CONFIG_RTLWIFI_USB=m
CONFIG_RTL8XXXU=m
CONFIG_RTL8XXXU_UNTESTED=y

# ath9k
CONFIG_ATH9K=m
CONFIG_ATH9K_HTC=m

# Packet socket (required for injection)
CONFIG_PACKET=y
CONFIG_PACKET_DIAG=y
